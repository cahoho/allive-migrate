# ============================================================
# 众生迁徙 (Allive Migration) 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际的 Supabase 项目信息
# 注意：.env 不应提交到 Git 仓库
# ============================================================

# Supabase 项目 URL（在 Supabase Dashboard → Settings → API 中获取）
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 匿名密钥（anon/public key，可以安全暴露在客户端代码中）
VITE_SUPABASE_ANON_KEY=your-anon-key-here
